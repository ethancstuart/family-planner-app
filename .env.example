# Copy this file to .env.local and fill in real values
# cp .env.example .env.local

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Google Calendar OAuth (Phase 4)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Spoonacular Recipe API (Phase 2)
# SPOONACULAR_API_KEY=your_spoonacular_key

# Site URL (used for invite links; defaults to localhost:3000 in dev)
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Note: Claude API key is stored per-household in the database, not as an env var.
# Add it via Settings > API Keys after creating a household.
